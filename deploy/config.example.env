# MioOJ 配置模板（可复制为 local.env / production.env，勿提交真实密码）
# 用法: cp deploy/config.example.env deploy/local.env  然后编辑 local.env

VIBEOJ_ENV=local
VIBEOJ_PORT=8081
VIBEOJ_DB_HOST=127.0.0.1
VIBEOJ_DB_PORT=3306
VIBEOJ_DB_USER=VibeOJUser
VIBEOJ_DB_PASSWORD=your_password_here
VIBEOJ_DB_NAME=vibeoj
VIBEOJ_DB_POOL_SIZE=8
VIBEOJ_WEB_ROOT=web
VIBEOJ_TMP_DIR=/tmp/oj
VIBEOJ_JUDGE_WORKERS=4
VIBEOJ_LOG_FILE=
VIBEOJ_LOG_LEVEL=1

# 仅 production.env 需要（Nginx / 部署脚本读取，不参与后端启动）
# DOMAIN=rinr.top
# PUBLIC_IP=your.public.ip.here
